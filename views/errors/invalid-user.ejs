      <path d="M 145 130 Q 130 150 128 180 Q 135 175 145 170 Q 142 155 148 140Z" fill="#1a1a1a"/>
      <path d="M 255 130 Q 270 150 272 180 Q 265 175 255 170 Q 258 155 252 140Z" fill="#1a1a1a"/>
      <rect x="144" y="118" width="112" height="18" rx="4" fill="#2a2a2a" stroke="#777" stroke-width="1"/>
      <circle cx="200" cy="127" r="8" fill="none" stroke="#888" stroke-width="1.5"/>
      <line x1="195" y1="122" x2="205" y2="132" stroke="#888" stroke-width="1.5"/>
      <!-- Eyes closed - looking away -->
      <path d="M 164 162 Q 178 155 192 162" stroke="#8a6040" stroke-width="2.5" fill="none"/>
      <path d="M 208 162 Q 222 155 236 162" stroke="#8a6040" stroke-width="2.5" fill="none"/>
      <path d="M 178 175 Q 175 190 172 210" stroke="#6a3333" stroke-width="2" fill="none" stroke-linecap="round"/>
      <path d="M 222 175 Q 225 190 228 210" stroke="#6a3333" stroke-width="2" fill="none" stroke-linecap="round"/>
