  <div class="error-content">
    <div class="error-code-tag">// HANDLE NOT FOUND</div>
    <h1 class="error-code" style="font-size:clamp(3rem,8vw,6rem)">USER<br/>UNKNOWN</h1>
    <h2 class="error-title">
      <span class="error-handle">"<%= handle %>"</span><br/>
      DOES NOT EXIST.
    </h2>
    <p class="error-quote">
      <em>"Those who turn their hands against their comrades are sure to die a terrible death."</em><br/>
      — Itachi Uchiha
    </p>
    <p class="error-message">
      Double-check the handle spelling. Codeforces handles are case-sensitive.
    </p>
    <div class="error-actions">
      <a href="/" class="error-btn neo-box">SEARCH AGAIN</a>
    </div>
    <div class="sharingan-bg">
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="45" fill="none" stroke="#cc000033" stroke-width="2"/>
        <circle cx="50" cy="50" r="30" fill="#cc000022"/>
        <circle cx="50" cy="50" r="15" fill="none" stroke="#cc000055" stroke-width="1.5"/>
        <circle cx="50" cy="50" r="6" fill="#cc000066"/>
        <line x1="50" y1="5" x2="50" y2="95" stroke="#cc000033" stroke-width="1"/>
        <line x1="5" y1="50" x2="95" y2="50" stroke="#cc000033" stroke-width="1"/>
        <line x1="18" y1="18" x2="82" y2="82" stroke="#cc000033" stroke-width="1"/>
        <line x1="82" y1="18" x2="18" y2="82" stroke="#cc000033" stroke-width="1"/>
      </svg>
    </div>
