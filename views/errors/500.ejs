<div class="error-container">

  <div class="itachi-wrap itachi-amaterasu">
    <svg viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg" class="itachi-svg">
      <defs>
        <radialGradient id="amaterasuGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:#ff2200;stop-opacity:0.6"/>
          <stop offset="100%" style="stop-color:#000000;stop-opacity:0"/>
        </radialGradient>
        <filter id="fireGlow">
          <feGaussianBlur stdDeviation="5" result="blur"/>
          <feComposite in="SourceGraphic" in2="blur" operator="over"/>
        </filter>
      </defs>
      <!-- Amaterasu fire aura -->
      <ellipse cx="200" cy="300" rx="200" ry="250" fill="url(#amaterasuGlow)"/>
      <!-- Black flames -->
      <path d="M 160 240 Q 155 200 165 180 Q 170 210 168 230Z" fill="#0d0000" opacity="0.9"/>
      <path d="M 240 240 Q 245 195 235 175 Q 230 205 232 230Z" fill="#0d0000" opacity="0.9"/>
      <path d="M 200 230 Q 198 185 205 165 Q 210 195 208 225Z" fill="#0d0000" opacity="0.9"/>
      <path d="M 80 240 Q 60 350 50 480 L 350 480 Q 340 350 320 240 Q 280 200 200 195 Q 120 200 80 240Z"
            fill="#0d0000" stroke="#ff2200" stroke-width="2"/>
      <path d="M 100 300 Q 110 290 125 295 Q 130 285 145 288 Q 150 295 140 302 Z" fill="#ff2200" opacity="0.9"/>
      <path d="M 240 320 Q 250 308 268 312 Q 274 302 292 306 Q 298 315 285 323 Z" fill="#ff2200" opacity="0.9"/>
      <path d="M 155 215 Q 200 230 245 215 L 240 240 Q 200 255 160 240 Z" fill="#f0e8d8" stroke="#ddd" stroke-width="0.5"/>
      <rect x="185" y="190" width="30" height="30" rx="8" fill="#c8a882"/>
      <ellipse cx="200" cy="160" rx="60" ry="70" fill="#c8a882"/>
      <path d="M 145 120 Q 155 80 180 65 Q 200 55 220 65 Q 245 80 255 120 Q 265 90 258 60 Q 240 20 200 15 Q 160 20 142 60 Q 135 90 145 120Z" fill="#0d0000"/>
      <path d="M 145 130 Q 130 150 128 180 Q 135 175 145 170 Q 142 155 148 140Z" fill="#0d0000"/>
      <path d="M 255 130 Q 270 150 272 180 Q 265 175 255 170 Q 258 155 252 140Z" fill="#0d0000"/>
      <rect x="144" y="118" width="112" height="18" rx="4" fill="#1a0000" stroke="#ff2200" stroke-width="1"/>
      <circle cx="200" cy="127" r="8" fill="none" stroke="#ff2200" stroke-width="1.5"/>
      <line x1="195" y1="122" x2="205" y2="132" stroke="#ff2200" stroke-width="1.5"/>
      <path d="M 178 175 Q 175 190 172 210" stroke="#6a3333" stroke-width="2" fill="none" stroke-linecap="round"/>
      <path d="M 222 175 Q 225 190 228 210" stroke="#6a3333" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- Amaterasu eyes - full red -->
      <ellipse cx="178" cy="165" rx="14" ry="10" fill="#0d0000"/>
      <circle cx="178" cy="165" r="10" fill="#ff0000" filter="url(#fireGlow)"/>
      <circle cx="178" cy="165" r="5" fill="#1a0000"/>
      <ellipse cx="222" cy="165" rx="14" ry="10" fill="#0d0000"/>
      <circle cx="222" cy="165" r="10" fill="#ff0000" filter="url(#fireGlow)"/>
      <circle cx="222" cy="165" r="5" fill="#1a0000"/>
      <path d="M 198 180 Q 200 188 202 180" stroke="#b09070" stroke-width="1.5" fill="none"/>
      <path d="M 190 198 Q 200 193 210 198" stroke="#8a5a5a" stroke-width="2" fill="none" stroke-linecap="round"/>
    </svg>
  </div>

  <div class="error-content">
    <div class="error-code-tag">// SERVER ERROR</div>
    <h1 class="error-code error-code-red">500</h1>
    <h2 class="error-title">AMATERASU<br/>HAS STRUCK.</h2>
    <p class="error-quote">
      <em>"These eyes of mine see through everything."</em><br/>
      — Itachi Uchiha
    </p>
    <p class="error-message">
      An internal server error occurred. The black flames consume all.
      <% if (error) { %><br/><code class="error-debug"><%= error %></code><% } %>
    </p>
    <div class="error-actions">
      <a href="/" class="error-btn neo-box">FLEE THE FLAMES</a>
    </div>
    <div class="sharingan-bg sharingan-red">
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="45" fill="none" stroke="#ff000033" stroke-width="2"/>
        <circle cx="50" cy="50" r="30" fill="#ff000022"/>
        <circle cx="50" cy="50" r="15" fill="none" stroke="#ff000055" stroke-width="1.5"/>
        <circle cx="50" cy="50" r="6" fill="#ff000066"/>
        <line x1="50" y1="5" x2="50" y2="95" stroke="#ff000033" stroke-width="1"/>
        <line x1="5" y1="50" x2="95" y2="50" stroke="#ff000033" stroke-width="1"/>
        <line x1="18" y1="18" x2="82" y2="82" stroke="#ff000033" stroke-width="1"/>
        <line x1="82" y1="18" x2="18" y2="82" stroke="#ff000033" stroke-width="1"/>
      </svg>
    </div>
  </div>

</div>
