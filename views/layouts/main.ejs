<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>

  <!-- Custom SVG Favicon - Codeforces bar chart style -->
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&family=Syne:wght@400;700;800&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <!-- Noise overlay -->
  <div class="noise-overlay"></div>

  <!-- Floating grid bg -->
  <div class="grid-bg"></div>

  <!-- Navbar -->
  <nav class="navbar">
    <a href="/" class="nav-logo">
      <span class="logo-bracket">[</span>CF<span class="logo-dot">.</span>TRACK<span class="logo-bracket">]</span>
    </a>
    <div class="nav-links">
      <a href="/" class="nav-link">HOME</a>
      <a href="https://codeforces.com" target="_blank" class="nav-link nav-external">CODEFORCES ↗</a>
    </div>
  </nav>

  <!-- Main content -->
  <main class="main-content">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-text">BUILT WITH <span class="footer-heart">♥</span> FOR COMPETITIVE PROGRAMMERS BY </span>
      <span class="footer-divider">///</span>
      <span class="footer-text">MADE BY DEVANG RANA</span>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
